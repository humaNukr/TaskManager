<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KMA.TaskManager.Maui.Pages.ProjectDetails"
             Title="Деталі проєкту">

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="20">

			<Frame BorderColor="DarkGoldenrod"
                   CornerRadius="0"
                   HasShadow="True"
                   Padding="0">

				<VerticalStackLayout Spacing="0">

					<BoxView HeightRequest="2" Color="DarkGoldenrod" VerticalOptions="Start"/>

					<VerticalStackLayout Padding="15" Spacing="10">
						<Label Text="{Binding Name, StringFormat='ПРОЄКТ: {0}'}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="Black" />

						<Label Text="{Binding ProjectType, StringFormat='Тип: {0}'}"
                               TextColor="Gray"
                               FontSize="14" />
					</VerticalStackLayout>

					<BoxView HeightRequest="1" Color="DarkGoldenrod" Margin="0" />

					<VerticalStackLayout Padding="15" Spacing="5">
						<HorizontalStackLayout Spacing="10">
							<Label Text="Прогрес:" FontAttributes="Bold" VerticalOptions="Center"/>
							<Label Text="{Binding Progress, StringFormat='{0:F1}%'}"
                                   TextColor="DarkCyan"
                                   VerticalOptions="Center"/>
						</HorizontalStackLayout>

						<ProgressBar Progress="{Binding ProgressFraction}"
                                     ProgressColor="DarkCyan"
                                     HeightRequest="15" />

						<Label Text="{Binding ProgressStats}"
                               FontSize="12"
                               TextColor="Gray" />
					</VerticalStackLayout>

					<BoxView HeightRequest="1" Color="DarkGoldenrod" />

					<VerticalStackLayout Padding="15" Spacing="5">
						<Label Text="ОПИС:"
                               TextColor="Gray"
                               FontSize="12"
                               FontAttributes="Bold" />

						<Label Text="{Binding Description}"
                               FontSize="16"
                               LineBreakMode="WordWrap" />
					</VerticalStackLayout>

					<BoxView HeightRequest="2" Color="DarkGoldenrod" VerticalOptions="End"/>
				</VerticalStackLayout>
			</Frame>
            <Label Text="ЗАВДАННЯ ПРОЄКТУ" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="DarkGoldenrod"
                   Margin="0,10,0,5" />

            <CollectionView x:Name="TasksListView" SelectionMode="None" HeightRequest="400">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,5" Padding="12" CornerRadius="5" BorderColor="LightGray">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTaskTapped" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0" FontSize="20" VerticalOptions="Center" Margin="0,0,15,0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="Text" Value="✅" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="False">
                                            <Setter Property="Text" Value="⏳" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding DueDate, StringFormat='Дедлайн: {0:dd.MM.yyyy}'}" 
                                           FontSize="12" 
                                           TextColor="Gray" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
	</ScrollView>
</ContentPage>