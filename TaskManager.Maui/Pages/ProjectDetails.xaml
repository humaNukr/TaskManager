<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KMA.TaskManager.UIModels"
             xmlns:uiModels="clr-namespace:KMA.TaskManager.UIModels;assembly=TaskManager.UIModels"
             x:Class="KMA.TaskManager.Maui.Pages.ProjectDetails"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Деталі проєкту">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Frame BackgroundColor="{StaticResource CardBackground}" 
                   BorderColor="{StaticResource ThemeGoldenrod}"
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="0"
                   IsClippedToBounds="True">

                <VerticalStackLayout Spacing="0">
                    <BoxView HeightRequest="4" Color="{StaticResource ThemeGoldenrod}" VerticalOptions="Start"/>

                    <VerticalStackLayout Padding="20,15,20,15" Spacing="5">
                        <Label Text="{Binding Name, StringFormat='ПРОЄКТ: {0}'}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <Label Text="{Binding ProjectType, StringFormat='Тип: {0}'}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />

                    <VerticalStackLayout Padding="20,15,20,15" Spacing="8">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Прогрес:" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="{Binding Progress, StringFormat='{0:F1}%'}"
                                   TextColor="{StaticResource ThemeCyan}"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <ProgressBar Progress="{Binding ProgressFraction}"
                                     ProgressColor="{StaticResource ThemeCyan}"
                                     HeightRequest="12" />

                        <Label Text="{Binding ProgressStats}"
                               FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" />

                    <VerticalStackLayout Padding="20,15,20,20" Spacing="8">
                        <Label Text="ОПИС"
                               TextColor="{StaticResource ThemeGoldenrod}"
                               FontSize="12"
                               FontAttributes="Bold" />

                        <Label Text="{Binding Description}"
                               FontSize="16"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Label Text="ЗАВДАННЯ ПРОЄКТУ" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource ThemeGoldenrod}"
                   Margin="0,10,0,0" />

            <CollectionView x:Name="TasksListView" SelectionMode="None" HeightRequest="400">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="uiModels:TaskUIModel">
                        <Frame Margin="0,6" Padding="15" CornerRadius="10" BorderColor="{StaticResource BorderColor}" BackgroundColor="{StaticResource CardBackground}" HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTaskTapped" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0" FontSize="22" VerticalOptions="Center" Margin="0,0,15,0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="Text" Value="✅" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="False">
                                            <Setter Property="Text" Value="⏳" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Name}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding DueDate, StringFormat='Дедлайн: {0:dd.MM.yyyy}'}" 
                                           FontSize="13" 
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>