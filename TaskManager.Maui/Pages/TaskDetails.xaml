<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KMA.TaskManager.Maui.Pages.TaskDetails"
             Title="Деталі завдання">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="{Binding Name}" 
                   FontSize="26" 
                   FontAttributes="Bold" 
                   TextColor="Black" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="Статус:" FontAttributes="Bold" VerticalOptions="Center" />
                <Frame Padding="8,4" CornerRadius="15" BackgroundColor="GhostWhite" BorderColor="LightGray">
                    <Label FontSize="14" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                <Setter Property="Text" Value="Завершено ✅" />
                                <Setter Property="TextColor" Value="DarkGreen" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="False">
                                <Setter Property="Text" Value="В процесі ⏳" />
                                <Setter Property="TextColor" Value="DarkGoldenrod" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Frame>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Label Text="Пріоритет:" FontAttributes="Bold" VerticalOptions="Center" />
                <Label Text="{Binding Priority}" 
                       FontSize="16" 
                       TextColor="DarkBlue" 
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Label Text="Виконати до:" FontAttributes="Bold" VerticalOptions="Center" />
                <Label Text="{Binding DueDate, StringFormat='{0:dd MMMM yyyy}'}" 
                       TextColor="Black" 
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Label Text="Стан часу:" FontAttributes="Bold" VerticalOptions="Center" />
                <Label FontSize="14" VerticalOptions="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsOverdue}" Value="True">
                            <Setter Property="Text" Value="Прострочено ⚠️" />
                            <Setter Property="TextColor" Value="Red" />
                            <Setter Property="FontAttributes" Value="Bold" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsOverdue}" Value="False">
                            <Setter Property="Text" Value="В межах норми 🟢" />
                            <Setter Property="TextColor" Value="DarkGreen" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="ОПИС" FontSize="12" FontAttributes="Bold" TextColor="Gray" />

            <Frame BackgroundColor="#F9F9F9" Padding="15" CornerRadius="8" HasShadow="False">
                <Label Text="{Binding Description}" 
                       FontSize="16" 
                       LineBreakMode="WordWrap" />
            </Frame>

           

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>