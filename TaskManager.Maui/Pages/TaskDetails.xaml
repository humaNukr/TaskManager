<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KMA.TaskManager.Maui.Pages.TaskDetails"
             BackgroundColor="{StaticResource PageBackground}"
             Title="Деталі завдання">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame BackgroundColor="{StaticResource CardBackground}" 
                   BorderColor="{StaticResource BorderColor}"
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="20">
                <VerticalStackLayout Spacing="15">

                    <Label Text="{Binding Name}" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource TextPrimary}" />

                    <BoxView HeightRequest="1" 
                             Color="{StaticResource BorderColor}" />

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Статус:" 
                               TextColor="{StaticResource TextSecondary}" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center" />
                        <Frame Padding="12,6" 
                               CornerRadius="8" 
                               BackgroundColor="#F9F9F9"
                               BorderColor="{StaticResource BorderColor}">
                            <Label FontSize="14"
                                   FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" 
                                                 Binding="{Binding IsCompleted}"
                                                 Value="True">
                                        <Setter Property="Text"
                                                Value="Завершено ✅" />
                                        <Setter Property="TextColor"
                                                Value="{StaticResource SuccessColor}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" 
                                                 Binding="{Binding IsCompleted}"
                                                 Value="False">
                                        <Setter Property="Text"
                                                Value="В процесі ⏳" />
                                        <Setter Property="TextColor"
                                                Value="{StaticResource ThemeGoldenrod}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Frame>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{StaticResource CardBackground}" 
                   BorderColor="{StaticResource BorderColor}"
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="20">
                <Grid RowDefinitions="Auto, Auto, Auto"
                      ColumnDefinitions="*, *"
                      RowSpacing="15">

                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="Пріоритет:"
                           TextColor="{StaticResource TextSecondary}"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                    <Label Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding Priority}"
                           FontAttributes="Bold" FontSize="16"
                           HorizontalOptions="End">
                        <!-- Візуальна індикація статусу та пріоритету завдання за допомогою DataTriggers для уникнення використання конвертерів у Code-Behind -->
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding Priority}"
                                         Value="Critical">
                                <Setter Property="TextColor"
                                        Value="{StaticResource DangerColor}" />
                            </DataTrigger>

                            <DataTrigger TargetType="Label" 
                                         Binding="{Binding Priority}"
                                         Value="High">
                                <Setter Property="TextColor"
                                        Value="{StaticResource ThemeDarkPink}" />
                            </DataTrigger>

                            <DataTrigger TargetType="Label"
                                         Binding="{Binding Priority}"
                                         Value="Medium">
                                <Setter Property="TextColor"
                                        Value="{StaticResource ThemeCyan}" />
                            </DataTrigger>

                            <DataTrigger TargetType="Label"
                                         Binding="{Binding Priority}" 
                                         Value="Low">
                                <Setter Property="TextColor" 
                                        Value="{StaticResource TextSecondary}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="Виконати до:"
                           TextColor="{StaticResource TextSecondary}" 
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                    <Label Grid.Row="1" 
                           Grid.Column="1" 
                           Text="{Binding DueDate, StringFormat='{0:dd MMMM yyyy}'}"
                           TextColor="{StaticResource TextPrimary}"
                           FontAttributes="Bold" 
                           HorizontalOptions="End"/>

                    <Label Grid.Row="2" 
                           Grid.Column="0"
                           Text="Ліміт часу:"
                           TextColor="{StaticResource TextSecondary}" 
                           FontAttributes="Bold" 
                           VerticalOptions="Center"/>
                    <Label Grid.Row="2"
                           Grid.Column="1"
                           FontSize="14" 
                           FontAttributes="Bold"
                           HorizontalOptions="End">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" 
                                         Binding="{Binding IsOverdue}" 
                                         Value="True">
                                <Setter Property="Text" 
                                        Value="Прострочено ⚠️" />
                                <Setter Property="TextColor"
                                        Value="{StaticResource DangerColor}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding IsOverdue}"
                                         Value="False">
                                <Setter Property="Text"
                                        Value="В межах норми 🟢" />
                                <Setter Property="TextColor"
                                        Value="{StaticResource SuccessColor}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>
            </Frame>

            <Frame BackgroundColor="{StaticResource CardBackground}" 
                   BorderColor="{StaticResource BorderColor}"
                   CornerRadius="12" 
                   HasShadow="True" 
                   Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="ОПИС ЗАВДАННЯ" 
                           FontSize="12" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource ThemeGoldenrod}" />
                    <Label Text="{Binding Description}" 
                           FontSize="16" 
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>