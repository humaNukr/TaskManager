<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KMA.TaskManager.Maui.Pages.MainPage"
             Title="Мої Проєкти">

    <Grid RowDefinitions="Auto, *">
        <Label Grid.Row="0" 
               Text="Список проєктів" 
               FontSize="24" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               Margin="10"/>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding .}" 
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10,5" Padding="15" CornerRadius="8">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProjectTapped" NumberOfTapsRequired="1"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="{Binding .}" 
                                   FontSize="20" 
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Progress, StringFormat='Прогрес: {0}%'}" 
                                   FontSize="14" 
                                   TextColor="Gray" 
                                   Margin="0,5,0,0" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>